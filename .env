# ======================================================================
# VARIÁVEIS DE AMBIENTE - DOCKER COMPOSE
# ======================================================================

# ----------------------------------------------------------------------
# BANCO DE DADOS (POSTGRES)
# ----------------------------------------------------------------------
POSTGRES_USER=gitea
POSTGRES_PASSWORD=gitea_password_secreta
POSTGRES_DB=gitea

# ----------------------------------------------------------------------
# CLOUDFLARED (TÚNEL CLOUDFLARE)
# ----------------------------------------------------------------------
# Obtenha seu token em: https://one.dash.cloudflare.com/
# Após criar o túnel, cole apenas o token (sem o comando 'tunnel run')
TUNNEL_TOKEN=eyJhIjoiMjVmMDQzNzZhNzdhYzI4OWZiZGZjNTVmNTU5YmNlZGUiLCJ0IjoiZjRjZmQ3MjctMjRiNS00OTdhLTg1Y2QtNmIxMzk0MjYxODFmIiwicyI6Ik1EVmpOekJsTXpndE9XVmhOQzAwWWpsaUxUaGlZV1l0TnpobFlUZzNOMlExTXpNMyJ9

# ----------------------------------------------------------------------
# TRAEFIK (AUTENTICAÇÃO)
# ----------------------------------------------------------------------
# Gere o hash da senha com: htpasswd -nbB admin sua_senha
# IMPORTANTE: No arquivo .env use apenas $ (dólar simples)
# Quando colocar diretamente no docker-compose.yml use $$ (dólar duplo)
TRAEFIK_AUTH_USERS=admin:$$2y$$05$$fSucdC6e76oSwaWBacs2cOtyXfa77DdRc894cVNzwhP5p1FHWWXqK

# ----------------------------------------------------------------------
# GITEA
# ----------------------------------------------------------------------
USER_UID=1000
USER_GID=1000
APP_NAME=Model Code Git

# Conexão com Postgres (deve corresponder às credenciais do banco)
GITEA_DB_TYPE=postgres
GITEA_DB_HOST=db:5432
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWD=gitea_password_secreta

# ----------------------------------------------------------------------
# DOMÍNIOS
# ----------------------------------------------------------------------
TRAEFIK_DOMAIN=modelinfra-traefik.triadevsolutions.com.br
GITEA_DOMAIN=modelinfra-git.triadevsolutions.com.br
JENKINS_DOMAIN=modelinfra-jenkins.triadevsolutions.com.br

# ----------------------------------------------------------------------
# GIT SERVICE (MICROSERVIÇO)
# ----------------------------------------------------------------------
# Token de admin do Gitea (Settings -> Applications -> Generate Token)
GITEA_ADMIN_TOKEN=f977bb51f2778ebde865ba5b969ad8de62ab5b0f

# Base para clone HTTP (para Jenkins interno pode ser http://gitea:3000)
GIT_CLONE_BASE_URL=http://gitea:3000

GIT_SERVICE_DOMAIN=modelinfra-gitservice.triadevsolutions.com.br

# ----------------------------------------------------------------------
# ORCHESTRATOR SERVICE
# ----------------------------------------------------------------------
ORCHESTRATOR_DOMAIN=modelinfra-orchestrator.triadevsolutions.com.br

# Domínio base para gerar Host(${subdomain}.${BASE_DOMAIN}) automaticamente
BASE_DOMAIN=triadevsolutions.com.br

# Middlewares padrão do Traefik para aplicar nos containers deployados
TRAEFIK_DEFAULT_MIDDLEWARES=modelcode-compress

# Jenkins (ajustar conforme seu serviço Jenkins)
JENKINS_BASE_URL=http://jenkins:8080
JENKINS_USER=modelcode
JENKINS_API_TOKEN=
JENKINS_JOB_NAME=

# Jenkins bootstrap (aplica apenas na PRIMEIRA subida, com volume vazio)
JENKINS_ADMIN_ID=modelcode
JENKINS_ADMIN_PASSWORD=modelcode123456

# Nome REAL da rede onde os apps dos clientes rodam.
# Se você sobe via Portainer Stack com nome "modelcode-infra", use: modelcode-infra_apps-net
APPS_NETWORK_NAME=apps-net

# ----------------------------------------------------------------------
# PÁGINA 404
# ----------------------------------------------------------------------
ERROR_404_DOMAIN=404.triadevsolutions.com.br
